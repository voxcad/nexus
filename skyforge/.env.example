# GCP
SKYFORGE_GCP_PROJECT_ID=
SKYFORGE_GCS_RAW_BUCKET=skyforge-raw
SKYFORGE_GCS_OUTPUT_BUCKET=skyforge-output
SKYFORGE_PUBSUB_TOPIC=skyforge-jobs
SKYFORGE_PUBSUB_SUBSCRIPTION=skyforge-jobs-sub

# Cloud SQL (PostgreSQL + PostGIS)
SKYFORGE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skyforge

# Firebase Auth
SKYFORGE_FIREBASE_PROJECT_ID=

# Gemini
SKYFORGE_GEMINI_API_KEY=
SKYFORGE_GEMINI_MODEL=gemini-2.5-pro

# Stripe
SKYFORGE_STRIPE_SECRET_KEY=
SKYFORGE_STRIPE_WEBHOOK_SECRET=

# App
SKYFORGE_API_URL=http://localhost:8000
SKYFORGE_WEB_URL=http://localhost:3000
SKYFORGE_ENVIRONMENT=development
SKYFORGE_WORKER_SECRET=change-me-in-production
SKYFORGE_SIGNED_URL_EXPIRY_MINUTES=60
SKYFORGE_SHARE_TOKEN_EXPIRY_DAYS=30

# Frontend (public vars)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Docker Compose overrides
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
